<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <input>
    <net-file value="city.net.xml"/>
    <route-files value="city.rou.xml"/>
  </input>
  <time>
    <begin value="0"/>
    <end value="86400"/>
    <step-length value="0.5"/>
  </time>
  <report>
    <no-warnings value="true"/>
    <no-step-log value="true"/>
  </report>
</configuration>
